# ===========================
airflow.db
airflow.cfg
webserver_config.py
logs/
dags/__pycache__/
plugins/__pycache__/
*.pid
*.log
*.err
.airflow_db

# Astro CLI
.astro/
.dockerignore
Dockerfile

